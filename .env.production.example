# Variables d'environnement PRODUCTION
# Utilisé par les scripts snapshot (create/restore)
# Copiez vers .env.production et renseignez les vraies valeurs

# Base de données production (Neon)
DATABASE_URL="postgresql://user:password@prod-host:5432/athanor_prod"
DIRECT_DATABASE_URL="postgresql://user:password@prod-host:5432/athanor_prod"

# Cloudinary PRODUCTION (source pour snapshots)
CLOUDINARY_CLOUD_NAME_PROD="your-prod-cloud"
CLOUDINARY_API_KEY_PROD="your-prod-key"
CLOUDINARY_API_SECRET_PROD="your-prod-secret"

# Cloudinary DEV (destination pour snapshots)
CLOUDINARY_CLOUD_NAME_DEV="your-dev-cloud"
CLOUDINARY_API_KEY_DEV="your-dev-key"
CLOUDINARY_API_SECRET_DEV="your-dev-secret"

# Zotero (bibliographie)
ZOTERO_GROUP_ID=your-group-id
ZOTERO_API_KEY=your-api-key

# Note : les variables d'exécution (NEXTAUTH_SECRET, GITHUB_*,
# SENTRY_*, etc.) sont configurées directement dans Vercel.
# Voir .env.example pour la liste complète.
