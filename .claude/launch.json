{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["dotenv-cli", "-e", ".env.local", "--", "npx", "prisma", "studio"],
      "port": 5555
    },
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up", "-d"],
      "port": 5432
    }
  ]
}
